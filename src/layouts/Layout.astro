---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'RandomPicks — Servidor CS2 Minigames | Bhop, Rangos y Tienda de Skins', description = 'Servidor de CS2 con minigames, bhop, sistema de rangos y tienda de skins. Comunidad española en Discord. Conéctate gratis: cs2.randompicks.es:27015' } = Astro.props;
const url = 'https://randompicks.es';
const ogImage = `${url}/random_picks_logo.jpg`;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="servidor cs2, cs2 minigames, cs2 bhop, cs2 español, servidor cs2 españa, cs2 mg, cs2 community server, cs2 ranks, cs2 tienda skins, counter strike 2 servidor, randompicks, cs2 surf, servidor cs2 gratis, cs2 bhop server, minigames cs2 españa, comunidad cs2" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="RandomPicks CS2" />
    <meta name="theme-color" content="#FF6B2B" />
    <link rel="canonical" href={url} />

    <!-- Open Graph (WhatsApp, Facebook, Discord) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="RandomPicks — Servidor CS2 Minigames" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="RandomPicks CS2" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="RandomPicks — Servidor CS2 Minigames" />

    <!-- Schema.org: WebSite -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "RandomPicks CS2",
      "url": "https://randompicks.es",
      "description": "Servidor de CS2 con minigames, bhop, sistema de rangos y tienda de skins. Comunidad española.",
      "inLanguage": "es",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://randompicks.es/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Schema.org: Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "RandomPicks CS2",
      "url": "https://randompicks.es",
      "logo": "https://randompicks.es/random_picks_logo.jpg",
      "sameAs": ["https://discord.gg/HSMZT6njnk"],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "https://discord.gg/HSMZT6njnk",
        "availableLanguage": "Spanish"
      }
    }
    </script>

    <!-- Schema.org: VideoGame -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "VideoGame",
      "name": "RandomPicks — Servidor CS2 Minigames",
      "description": "Servidor comunitario de Counter-Strike 2 con modos de juego como minigames, bhop, sistema de rangos y tienda de skins. Gratis y en español.",
      "url": "https://randompicks.es",
      "applicationCategory": "Game",
      "operatingSystem": "Windows",
      "gamePlatform": "PC",
      "genre": ["Minigames", "Bhop", "FPS", "Community Server"],
      "inLanguage": "es",
      "image": "https://randompicks.es/random_picks_logo.jpg",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock"
      },
      "sameAs": ["https://discord.gg/HSMZT6njnk"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "1",
        "bestRating": "5"
      }
    }
    </script>

    <!-- Preload fuentes críticas -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@700&family=Inter:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #FF6B2B;
    --orange-glow: #FF6B2B66;
    --orange-dim: #cc5522;
    --bg: #0A0A0F;
    --bg2: #0F0F1A;
    --bg3: #141425;
    --surface: #1A1A2E;
    --surface2: #22223A;
    --border: #2A2A45;
    --text: #E8E8F0;
    --muted: #7070A0;
    --discord: #5865F2;
    --discord-hover: #4752c4;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
  }

  h1, h2, h3, h4 {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--orange); }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px var(--orange-glow); }
    50% { box-shadow: 0 0 40px var(--orange-glow), 0 0 80px #FF6B2B33; }
  }
  @keyframes scan {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100vh); }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes counter {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes rotate-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes flicker {
    0%, 100% { opacity: 1; }
    92% { opacity: 1; }
    93% { opacity: 0.4; }
    94% { opacity: 1; }
    96% { opacity: 0.7; }
    97% { opacity: 1; }
  }
</style>
