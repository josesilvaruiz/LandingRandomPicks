---
import Layout from '../layouts/Layout.astro';

const modes = [
  {
    icon: '🎪',
    name: 'Mini Games',
    desc: 'Variedad de juegos en un solo servidor. Siempre hay algo nuevo con lo que reírse.',
    tag: 'PRINCIPAL',
  },
  {
    icon: '💣',
    name: 'Bhop',
    desc: 'Encadena saltos perfectos y sube en el ranking. ¿Tienes el nivel?',
    tag: 'RANKING',
  },
  {
    icon: '🏅',
    name: 'Rangos',
    desc: 'Sistema de rangos para que tu progreso siempre cuente. Escala posiciones.',
    tag: 'PROGRESO',
  },
  {
    icon: '🛍️',
    name: 'Tienda de skins',
    desc: 'Gana créditos jugando y canjéalos por skins en la tienda del servidor.',
    tag: 'NUEVO',
  },
];

const stats = [
  { value: '¡NUEVO!', label: 'Servidor recién abierto' },
  { value: '1', label: 'Servidor online' },
  { value: 'FREE', label: 'Acceso gratuito' },
  { value: 'CS2', label: 'Actualizado' },
];

const features = [
  { icon: '🏅', title: 'Sistema de rangos', desc: 'Tu progreso queda guardado. Sube de rango jugando al bhop y en los minigames.' },
  { icon: '🛍️', title: 'Tienda de skins', desc: 'Gana créditos simplemente jugando y gástalos en skins dentro del servidor.' },
  { icon: '🎪', title: 'Minigames variados', desc: 'El modo principal del servidor. Siempre hay algo diferente con lo que pasarlo bien.' },
  { icon: '💬', title: 'Comunidad en Discord', desc: 'Canal directo con los admins. Propón modos, reporta bugs y estate al tanto de novedades.' },
];
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="logo-img-link">
        <img src="/random_picks_logo.jpg" alt="RandomPicks" style="height:44px;width:72px;object-fit:cover;object-position:center;border-radius:8px;display:block;" />
      </a>
      <ul class="nav-links">
        <li><a href="#">Home</a></li>
        <li><a href="#modos">Modos</a></li>
        <li><a href="#features">Features</a></li>
        <li><a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener" class="nav-discord">Discord</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobile-menu">
      <a href="#">Home</a>
      <a href="#modos">Modos</a>
      <a href="#features">Features</a>
      <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener">Discord</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="grid-overlay"></div>
      <div class="scanline"></div>
      <div class="orb orb1"></div>
      <div class="orb orb2"></div>
      <div class="orb orb3"></div>
    </div>

    <div class="hero-content">
      <div class="badge-pill">
        <span class="dot-pulse"></span>
        SERVIDORES EN LÍNEA · CS2
      </div>

      <h1 class="hero-title">
        El servidor de<br />
        <span class="title-highlight">
          <span class="title-text">minigames</span>
          <span class="title-underline"></span>
        </span><br />
        que estabas buscando
      </h1>

      <p class="hero-sub">
        Minigames, Bhop, rangos y tienda de skins.
        Únete a la comunidad desde el primer día.
      </p>

      <div class="hero-actions">
        <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener" class="btn-discord">
          <svg width="22" height="22" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440808 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.401291 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978Z" fill="currentColor"/></svg>
          Únete al Discord
        </a>
        <a href="#modos" class="btn-outline">
          Ver modos de juego
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
      </div>

      <div class="hero-meta">
        <div class="meta-item">
          <span class="meta-dot"></span>
          <span>Servidor recién abierto — sé de los primeros</span>
        </div>
      </div>

      <div class="server-ip" id="server-ip">
        <span class="ip-label">CONECTAR</span>
        <code class="ip-text">cs2.randompicks.es:27015</code>
        <button class="ip-copy" id="copy-btn" title="Copiar IP">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span id="copy-label">Copiar</span>
        </button>
      </div>
    </div>

    <div class="hero-visual">
      <div class="crosshair-wrap">
        <div class="crosshair">
          <div class="ch-ring ch-ring1"></div>
          <div class="ch-ring ch-ring2"></div>
          <div class="ch-lines">
            <div class="ch-h"></div>
            <div class="ch-v"></div>
          </div>
          <div class="ch-center"></div>
        </div>
        <div class="ch-label top-left">ONLINE</div>
        <div class="ch-label top-right">CS2</div>
        <div class="ch-label bot-left">RANKED</div>
        <div class="ch-label bot-right">24/7</div>
      </div>
    </div>
  </section>

  <!-- STATS TICKER -->
  <div class="ticker-wrap" id="stats">
    <div class="ticker">
      {stats.map(s => (
        <div class="ticker-item">
          <span class="ticker-val">{s.value}</span>
          <span class="ticker-label">{s.label}</span>
        </div>
      ))}
      {stats.map(s => (
        <div class="ticker-item" aria-hidden="true">
          <span class="ticker-val">{s.value}</span>
          <span class="ticker-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- MODOS -->
  <section class="section" id="modos">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">GAME MODES</div>
        <h2 class="section-title">Elige tu modo de juego</h2>
        <p class="section-sub">Servidores dedicados para cada estilo. Sin lag, sin excusas.</p>
      </div>

      <div class="modes-grid">
        {modes.map((m, i) => (
          <div class="mode-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="mode-tag">{m.tag}</div>
            <div class="mode-icon">{m.icon}</div>
            <h3 class="mode-name">{m.name}</h3>
            <p class="mode-desc">{m.desc}</p>
            <div class="mode-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section section-alt" id="features">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">POR QUÉ ELEGIRNOS</div>
        <h2 class="section-title">Todo lo que necesitas</h2>
        <p class="section-sub">Infraestructura de nivel pro para una experiencia de juego inigualable.</p>
      </div>

      <div class="features-grid">
        {features.map((f, i) => (
          <div class="feature-card" style={`animation-delay: ${i * 0.1}s`}>
            <div class="feature-icon-wrap">
              <span class="feature-icon">{f.icon}</span>
            </div>
            <div class="feature-body">
              <h3 class="feature-title">{f.title}</h3>
              <p class="feature-desc">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DISCORD CTA -->
  <section class="section discord-section" id="discord">
    <div class="container">
      <div class="discord-card">
        <div class="discord-bg-decor">
          <div class="dc-orb dc-orb1"></div>
          <div class="dc-orb dc-orb2"></div>
        </div>
        <div class="discord-content">
          <div class="discord-logo-wrap">
            <svg class="discord-logo-svg" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440808 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.401291 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978Z" fill="currentColor"/></svg>
          </div>
          <h2 class="discord-title">Únete a la comunidad</h2>
          <p class="discord-sub">
            Estamos empezando y buscamos los primeros jugadores. Únete ahora,
            ayuda a construir la comunidad y consigue los roles de fundador.
          </p>
          <div class="discord-perks">
            <div class="perk"><span>✓</span> Rol de fundador exclusivo</div>
            <div class="perk"><span>✓</span> Influye en los modos que añadimos</div>
            <div class="perk"><span>✓</span> Contacto directo con los admins</div>
            <div class="perk"><span>✓</span> Acceso gratuito a todos los modos</div>
          </div>
          <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener" class="btn-discord-big">
            <svg width="24" height="24" viewBox="0 0 71 55" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440808 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.401291 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978Z" fill="currentColor"/></svg>
            Entrar al servidor de Discord
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <img src="/random_picks_logo.jpg" alt="RandomPicks" style="height:36px;width:36px;object-fit:cover;object-position:center;border-radius:6px;display:block;opacity:0.85;" />
        <p class="footer-text">Servidor de minigames para CS2 · No afiliado con Valve Corporation</p>
        <div class="footer-links">
          <a href="#">Home</a>
          <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener">Discord</a>
          <span class="footer-ip">cs2.randompicks.es:27015</span>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo-img-link { display: flex; align-items: center; text-decoration: none; }
  .nav-logo {
    height: 40px;
    width: 40px;
    object-fit: cover;
    object-position: center;
    border-radius: 8px;
  }
  .footer-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    border-radius: 6px;
    opacity: 0.85;
  }
  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.02em;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-discord {
    color: var(--discord) !important;
    border: 1px solid var(--discord);
    padding: 6px 16px;
    border-radius: 6px;
    transition: background 0.2s !important;
  }
  .nav-discord:hover { background: var(--discord) !important; color: white !important; }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: 0.3s;
  }
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 16px 24px 20px;
    gap: 12px;
    border-top: 1px solid var(--border);
  }
  .mobile-menu a {
    color: var(--muted);
    text-decoration: none;
    font-weight: 500;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .mobile-menu.open { display: flex; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    padding: 120px 24px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }
  .hero-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,107,43,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,107,43,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,107,43,0.3), transparent);
    animation: scan 8s linear infinite;
    opacity: 0.5;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
  }
  .orb1 { width: 500px; height: 500px; background: var(--orange); top: -100px; right: -100px; animation: float 8s ease-in-out infinite; }
  .orb2 { width: 300px; height: 300px; background: #5865F2; bottom: 100px; left: -50px; animation: float 10s ease-in-out infinite reverse; }
  .orb3 { width: 200px; height: 200px; background: var(--orange); bottom: 50%; left: 40%; animation: float 12s ease-in-out infinite 2s; }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 620px;
    animation: fadeInUp 0.8s ease both;
  }
  .badge-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,107,43,0.1);
    border: 1px solid rgba(255,107,43,0.3);
    border-radius: 100px;
    padding: 6px 16px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--orange);
    margin-bottom: 24px;
  }
  .dot-pulse {
    width: 8px; height: 8px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse-glow 2s ease-in-out infinite;
    box-shadow: 0 0 8px #22c55e;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 24px;
    color: var(--text);
  }
  .title-highlight {
    position: relative;
    display: inline-block;
  }
  .title-text { color: var(--orange); animation: flicker 6s ease-in-out infinite; }
  .title-underline {
    position: absolute;
    bottom: -4px; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--orange), transparent);
    border-radius: 2px;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 500px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .btn-discord {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--discord);
    color: white;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(88,101,242,0.4);
  }
  .btn-discord:hover {
    background: var(--discord-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(88,101,242,0.5);
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    padding: 14px 24px;
    border-radius: 10px;
    font-weight: 500;
