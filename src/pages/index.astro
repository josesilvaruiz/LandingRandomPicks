---
import Layout from '../layouts/Layout.astro';

const modes = [
  {
    icon: '🎪',
    name: 'Mini Games',
    nameEn: 'Mini Games',
    desc: 'El modo principal del servidor. Variedad de juegos, risas garantizadas y siempre algo nuevo cada semana.',
    descEn: 'The server\'s main mode. Variety of games, guaranteed fun and always something new every week.',
    tag: 'PRINCIPAL',
    tagEn: 'MAIN',
    detail: 'Juega con hasta 32 jugadores en modos que cambian constantemente.',
    detailEn: 'Play with up to 32 players in constantly rotating game modes.',
  },
  {
    icon: '💨',
    name: 'Bhop',
    nameEn: 'Bhop',
    desc: 'Encadena saltos perfectos, mejora tu técnica y escala el ranking global del servidor.',
    descEn: 'Chain perfect jumps, improve your technique and climb the server\'s global ranking.',
    tag: 'RANKING',
    tagEn: 'RANKING',
    detail: 'Rankings persistentes. Tu mejor tiempo siempre guardado.',
    detailEn: 'Persistent rankings. Your best time always saved.',
  },
  {
    icon: '🏅',
    name: 'Sistema de Rangos',
    nameEn: 'Rank System',
    desc: 'Cada partida suma. Sube de rango, demuestra tu nivel y deja huella en el servidor.',
    descEn: 'Every match counts. Rank up, prove your skill and leave your mark on the server.',
    tag: 'PROGRESO',
    tagEn: 'PROGRESS',
    detail: 'Múltiples rangos desde Principiante hasta Élite.',
    detailEn: 'Multiple ranks from Beginner to Elite.',
  },
  {
    icon: '🛍️',
    name: 'Tienda de Skins',
    nameEn: 'Skin Shop',
    desc: 'Gana créditos jugando — sin pagar — y canjéalos por skins exclusivas del servidor.',
    descEn: 'Earn credits by playing — for free — and redeem them for exclusive server skins.',
    tag: 'GRATIS',
    tagEn: 'FREE',
    detail: 'Créditos por tiempo jugado, kills y logros.',
    detailEn: 'Credits earned by playtime, kills and achievements.',
  },
];

const faq = [
  {
    q: '¿El servidor es completamente gratuito?',
    qEn: 'Is the server completely free?',
    a: 'Sí, 100% gratis. Los créditos para la tienda de skins se ganan jugando. No hay compras dentro del juego ni ventajas de pago.',
    aEn: 'Yes, 100% free. Credits for the skin shop are earned by playing. No in-game purchases or pay-to-win advantages.',
  },
  {
    q: '¿Hay admins activos contra cheaters y toxicidad?',
    qEn: 'Are there active admins against cheaters and toxicity?',
    a: 'Sí. El equipo de RandomPicks monitoriza el servidor activamente. Hay un canal de reporte en Discord con respuesta rápida.',
    aEn: 'Yes. The RandomPicks team actively monitors the server. There is a report channel on Discord with fast response.',
  },
  {
    q: '¿Puedo jugar si no hablo español?',
    qEn: 'Can I play if I don\'t speak Spanish?',
    a: 'Totalmente. El servidor es de comunidad hispanohablante pero todos son bienvenidos. CS2 es un lenguaje universal.',
    aEn: 'Absolutely. The server is a Spanish-speaking community but everyone is welcome. CS2 is a universal language.',
  },
  {
    q: '¿Los rangos se resetean alguna vez?',
    qEn: 'Do ranks ever reset?',
    a: 'Los rangos no se resetean por defecto. Cualquier reset estacional se anunciará con antelación en el Discord con compensación para los jugadores activos.',
    aEn: 'Ranks do not reset by default. Any seasonal reset will be announced in advance on Discord with compensation for active players.',
  },
  {
    q: '¿Con qué frecuencia se añaden modos nuevos?',
    qEn: 'How often are new modes added?',
    a: 'La comunidad vota en Discord qué modos añadir. Tenemos un canal específico para propuestas y añadimos contenido de forma regular.',
    aEn: 'The community votes on Discord for which modes to add. We have a dedicated channel for suggestions and add content regularly.',
  },
  {
    q: '¿Cómo me conecto al servidor?',
    qEn: 'How do I connect to the server?',
    a: 'Abre CS2, activa la consola con ~ y escribe: connect cs2.randompicks.es:27015. También puedes buscar "RandomPicks" en el navegador de servidores.',
    aEn: 'Open CS2, open the console with ~ and type: connect cs2.randompicks.es:27015. You can also search for "RandomPicks" in the server browser.',
  },
];

const ranks = [
  { icon: '⬜', name: 'Principiante', nameEn: 'Beginner', color: '#7070A0' },
  { icon: '🟩', name: 'Veterano',     nameEn: 'Veteran',   color: '#22c55e' },
  { icon: '🟦', name: 'Experto',      nameEn: 'Expert',    color: '#3b82f6' },
  { icon: '🟪', name: 'Maestro',      nameEn: 'Master',    color: '#a855f7' },
  { icon: '🟧', name: 'Élite',        nameEn: 'Elite',     color: '#FF6B2B' },
];
---

<Layout>
  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="logo-img-link">
        <img src="/random_picks_logo.jpg" alt="RandomPicks" style="height:44px;width:72px;object-fit:cover;object-position:center;border-radius:8px;display:block;" />
      </a>
      <ul class="nav-links">
        <li><a href="#" data-i18n="nav-home">Home</a></li>
        <li><a href="#modos" data-i18n="nav-modos">Modos</a></li>
        <li><a href="#progresion" data-i18n="nav-progression">Progresión</a></li>
        <li><a href="#faq" data-i18n="nav-faq">FAQ</a></li>
        <li><a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener" class="nav-discord">Discord</a></li>
      </ul>
      <div class="nav-right">
        <button id="lang-toggle" class="lang-toggle" aria-label="Switch to English" title="Switch to English">
          <span class="lang-globe" aria-hidden="true">🌐</span>
          <span class="lang-es lang-active" id="lang-es">ES</span>
          <span class="lang-sep" aria-hidden="true">|</span>
          <span class="lang-en lang-inactive" id="lang-en">EN</span>
        </button>
        <button class="hamburger" id="hamburger" aria-label="Menú">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <div class="mobile-menu" id="mobile-menu">
      <a href="#" data-i18n="nav-home">Home</a>
      <a href="#modos" data-i18n="nav-modos">Modos</a>
      <a href="#progresion" data-i18n="nav-progression">Progresión</a>
      <a href="#faq" data-i18n="nav-faq">FAQ</a>
      <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener">Discord</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="grid-overlay"></div>
      <div class="scanline"></div>
      <div class="orb orb1"></div>
      <div class="orb orb2"></div>
      <div class="orb orb3"></div>
    </div>

    <div class="hero-content">
      <div class="badge-pill">
        <span class="dot-pulse"></span>
        <span data-i18n="hero-badge">ROL DE FUNDADOR DISPONIBLE — PLAZAS LIMITADAS</span>
      </div>

      <h1 class="hero-title" data-i18n-html="hero-title">
        El servidor CS2 de la<br />
        <span class="title-highlight">
          <span class="title-text">comunidad hispanohablante</span>
          <span class="title-underline"></span>
        </span>
      </h1>

      <p class="hero-sub" data-i18n="hero-sub">
        Minigames, Bhop con rankings y tienda de skins — todo gratis. Arrancamos ahora y los primeros que entren consiguen el rol de fundador en Discord.
      </p>

      <div class="hero-social-proof">
        <div class="sp-item">
          <span class="sp-dot"></span>
          <span data-i18n="sp-server">Servidor activo 24/7</span>
        </div>
        <span class="sp-sep">·</span>
        <div class="sp-item">
          <span data-i18n="sp-community">Comunidad hispanohablante</span>
        </div>
        <span class="sp-sep">·</span>
        <div class="sp-item">
          <span data-i18n="sp-welcome">Everyone welcome</span>
        </div>
      </div>

      <div class="hero-cta-block">
        <a href="https://discord.gg/HSMZT6njnk" target="_blank" rel="noopener" class="btn-primary">
          <svg width="22" height="22" viewBox="0 0 71 55" fill="none"><path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440808 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.401291 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978Z" fill="currentColor"/></svg>
          <span data-i18n="btn-discord">Entrar al Discord — consigue el rol de fundador</span>
        </a>
        <div class="btn-hint" data-i18n="btn-hint">Gratis · Sin registro previo · Rol de fundador para los primeros</div>
      </div>

      <div class="ip-gt-group">
        <div class="server-ip" id="server-ip">
          <span class="ip-label" data-i18n="ip-label">CONECTAR AHORA</span>
          <code class="ip-text">cs2.randompicks.es:27015</code>
          <button class="ip-copy" id="copy-btn" title="Copiar IP">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copy-label" data-i18n="copy-label">Copiar IP</span>
          </button>
        </div>
        <div class="hero-gametracker">
          <a href="https://www.gametracker.com/server_info/159.195.150.62:27015/" target="_blank" rel="noopener">
            <img src="https://cache.gametracker.com/server_info/159.195.150.62:27015/b_560_95_1.png" border="0" width="560" height="95" alt="GameTracker server stats" />
          </a>
        </div>
      </div>

    </div>

    <div class="hero-visual">
      <div class="crosshair-wrap">
        <div class="crosshair">
          <div class="ch-ring ch-ring1"></div>
          <div class="ch-ring ch-ring2"></div>
          <div class="ch-lines">
            <div class="ch-h"></div>
            <div class="ch-v"></div>
          </div>
          <div class="ch-center"></div>
        </div>
        <div class="ch-label top-left">ONLINE</div>
        <div class="ch-label top-right">CS2</div>
        <div class="ch-label bot-left">RANKED</div>
        <div class="ch-label bot-right">24/7</div>
      </div>
    </div>
  </section>

  <!-- VALUE STRIP -->
  <div class="value-strip">
    <div class="value-strip-inner">
      <div class="vs-item">
        <span class="vs-icon">🎮</span>
        <div>
          <div class="vs-title" data-i18n="vs-0-title">Minigames & Bhop</div>
          <div class="vs-sub" data-i18n="vs-0-sub">Modos que rotan cada semana</div>
        </div>
      </div>
      <div class="vs-divider"></div>
      <div class="vs-item">
        <span class="vs-icon">🏅</span>
        <div>
          <div class="vs-title" data-i18n="vs-1-title">Rankings reales</div>
          <div class="vs-sub" data-i18n="vs-1-sub">Tu progreso nunca se pierde</div>
        </div>
      </div>
      <div class="vs-divider"></div>
      <div class="vs-item">
        <span class="vs-icon">🛍️</span>
        <div>
          <div class="vs-title" data-i18n="vs-2-title">Skins por jugar</div>
          <div class="vs-sub" data-i18n="vs-2-sub">Sin pagar. Solo jugando.</div>
        </div>
      </div>
      <div class="vs-divider"></div>
      <div class="vs-item">
        <span class="vs-icon">💬</span>
        <div>
          <div class="vs-title" data-i18n="vs-3-title">Admins activos</div>
          <div class="vs-sub" data-i18n="vs-3-sub">Comunidad sin toxicidad</div>
        </div>
      </div>
    </div>
  </div>

  <!-- MODOS -->
  <section class="section" id="modos">
    <div class="container">
      <div class="section-header">
        <div class="section-tag" data-i18n="modes-tag">GAME MODES</div>
        <h2 class="section-title" data-i18n="modes-title">Todo lo que puedes jugar</h2>
        <p class="section-sub" data-i18n="modes-sub">Cuatro modos para cuatro tipos de jugador. Todos en el mismo servidor, todos gratis.</p>
      </div>
      <div class="modes-grid">
        {modes.map((m, i) => (
          <div class="mode-card" style={`animation-delay: ${i * 0.08}s`}>
            <div class="mode-tag" data-i18n={`mode-${i}-tag`}>{m.tag}</div>
            <div class="mode-icon">{m.icon}</div>
            <h3 class="mode-name" data-i18n={`mode-${i}-name`}>{m.name}</h3>
            <p class="mode-desc" data-i18n={`mode-${i}-desc`}>{m.desc}</p>
            <p class="mode-detail" data-i18n={`mode-${i}-detail`}>{m.detail}</p>
            <div class="mode-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRESIÓN -->
  <section class="section section-alt" id="progresion">
    <div class="container">
      <div class="section-header">
        <div class="section-tag" data-i18n="prog-tag">SISTEMA DE PROGRESIÓN</div>
        <h2 class="section-title" data-i18n="prog-title">Cada partida tiene valor</h2>
        <p class="section-sub" data-i18n="prog-sub">Rankea, gana créditos y personaliza tu experiencia. Todo por jugar.</p>
      </div>

      <div class="prog-grid">
        <!-- RANKS -->
        <div class="prog-card">
          <div class="prog-card-header">
            <span class="prog-card-icon">🏅</span>
            <h3 class="prog-card-title" data-i18n="prog-ranks-title">Sistema de Rangos</h3>
          </div>
          <p class="prog-card-desc" data-i18n="prog-ranks-desc">Cada partida en Bhop y Minigames suma puntos. Sube de rango y demuestra tu nivel frente a la comunidad.</p>
          <div class="rank-ladder">
            {ranks.map((r, i) => (
              <div class="rank-item" style={`animation-delay: ${i * 0.1}s`}>
                <span class="rank-icon">{r.icon}</span>
                <span class="rank-name" data-i18n={`rank-${i}`} style={`color: ${r.color}`}>{r.name}</span>
                {i === ranks.length - 1 && <span class="rank-badge" data-i18n="rank-top">TOP</span>}
              </div>
            ))}
          </div>
        </div>

        <!-- SKINS -->
        <div class="prog-card">
          <div class="prog-card-header">
            <span class="prog-card-icon">🛍️</span>
            <h3 class="prog-card-title" data-i18n="prog-skins-title">Tienda de Skins</h3>
          </div>
          <p class="prog-card-desc" data-i18n="prog-skins-desc">Gana créditos jugando y canjéalos por skins. Los jugadores VIP acceden a skins exclusivas y beneficios adicionales.</p>
          <div class="credits-flow">
            <div class="cf-step">
              <div class="cf-icon">🎮</div>
              <div class="cf-label" data-i18n="cf-0">Juega partidas</div>
            </div>
            <div class="cf-arrow">→</div>
            <div class="cf-step">
              <div class="cf-icon">💰</div>
              <div class="cf-label" data-i18n="cf-1">Gana créditos</div>
            </div>
            <div class="cf-arrow">→</div>
            <div class="cf-step">
              <div class="cf-icon">🎨</div>
              <div class="cf-label" data-i18n="cf-2">Consigue skins</div>
            </div>
          </div>
          <div class="credits-sources">
            <div class="cs-item"><span>✓</span> <span data-i18n="cs-0">Tiempo de juego</span></div>
            <div class="cs-item"><span>✓</span> <span data-i18n="cs-1">Kills y asistencias</span></div>
            <div class="cs-item"><span>✓</span> <span data-i18n="cs-2">Logros del servidor</span></div>
            <div class="cs-item cs-vip"><span>⭐</span> <span data-i18n="cs-3">VIP — skins exclusivas</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="section-header">
        <div class="section-tag" data-i18n="faq-tag">FAQ</div>
        <h2 class="section-title" data-i18n="faq-title">Preguntas frecuentes</h2>
        <p class="section-sub" data-i18n="faq-sub">Todo lo que necesitas saber antes de conectarte.</p>
      </div>
      <div class="faq-grid">
        {faq.map((item, i) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false" data-faq={i}>
              <span data-i18n={`faq-${i}-q`}>{item.q}</span>
              <span class="faq-chevron" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </span>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`}>
              <p data-i18n={`faq-${i}-a`}>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DISCORD CTA -->
  <section class="section discord-section" id="discord">
    <div class="container">
      <div class="discord-card">
        <div class="discord-bg-decor">
          <div class="dc-orb dc-orb1"></div>
          <div class="dc-orb dc-orb2"></div>
        </div>
        <div class="discord-content">
          <div class="discord-logo-wrap">
            <svg class="discord-logo-svg" viewBox="0 0 71 55" fill="none"><path d="M60.1045 4.8978C55.5792 2.8214 50.7265 1.2916 45.6527 0.41542C45.5603 0.39851 45.468 0.440808 45.4204 0.525289C44.7963 1.6353 44.105 3.0834 43.6209 4.2216C38.1637 3.4046 32.7345 3.4046 27.3892 4.2216C26.905 3.0581 26.1886 1.6353 25.5617 0.525289C25.5141 0.443589 25.4218 0.401291 25.3294 0.41542C20.2584 1.2888 15.4057 2.8186 10.8776 4.8978C10.8384 4.9147 10.8048 4.9429 10.7825 4.9795C1.57795 18.7309 -0.943561 32.1443 0.293408 45.3914C0.299005 45.4562 0.335386 45.5182 0.385761 45.5576C6.45866 50.0174 12.3413 52.7249 18.1147 54.5195C18.2071 54.5477 18.305 54.5139 18.3638 54.4378C19.7295 52.5728 20.9469 50.6063 21.9907 48.5383C22.0523 48.4172 21.9935 48.2735 21.8676 48.2256C19.9366 47.4931 18.0979 46.6 16.3292 45.5858C16.1893 45.5041 16.1781 45.304 16.3068 45.2082C16.679 44.9293 17.0513 44.6391 17.4067 44.3461C17.471 44.2926 17.5606 44.2813 17.6362 44.3151C29.2558 49.6202 41.8354 49.6202 53.3179 44.3151C53.3935 44.2785 53.4831 44.2898 53.5502 44.3433C53.9057 44.6363 54.2779 44.9293 54.6529 45.2082C54.7816 45.304 54.7732 45.5041 54.6333 45.5858C52.8646 46.6197 51.0259 47.4931 49.0921 48.2228C48.9662 48.2707 48.9102 48.4172 48.9718 48.5383C50.038 50.6034 51.2554 52.5699 52.5959 54.435C52.6519 54.5139 52.7526 54.5477 52.845 54.5195C58.6464 52.7249 64.529 50.0174 70.6019 45.5576C70.6551 45.5182 70.6887 45.459 70.6943 45.3942C72.1747 30.0791 68.2147 16.7757 60.1968 4.9823C60.1772 4.9429 60.1437 4.9147 60.1045 4.8978Z" fill="currentColor"/></svg>
          </div>
          <div class="founder-badge" data-i18n="founder-badge">🎖️ ROL DE FUNDADOR — PLAZAS LIMITADAS</div>
          <h2 class="discord-title" data-i18n="discord-title">Entra antes de que acabe el lanzamiento</h2>
          <p class="discord-sub" data-i18n="discord-sub">
            El rol de fundador es exclusivo para quienes entran durante el lanzamiento. Tendrás voz en los modos que añadimos, acceso a canales privados y el reconocimiento permanente de haber estado desde el inicio.
          </p>
          <div class="discord-perks">
            <div class="perk"><span aria-hidden="true">✓</span> <span data-i18n="perk-0">Rol de fundador permanente</span></div>
            <div class="perk"><span aria-hidden="true">✓</span> <span data-i18n="perk-1">Voto en los modos que añadimos</span></div>
            <div class="perk"><span aria-hidden="true">✓</span> <span data-i18n="perk-2">Contacto directo con los admins</span></div>
            <div class="perk"><span aria-hidden="true">✓</span> <span data-i18n="perk-3">Acceso a canales exclusivos</span></div>
          </div>
