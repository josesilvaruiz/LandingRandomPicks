    function applyLang(lang) {
      var dict = t[lang];
      document.querySelectorAll('[data-i18n]').forEach(function(el) {
        var key = el.getAttribute('data-i18n');
        if (dict[key] !== undefined) el.textContent = dict[key];
      });
      document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
        var key = el.getAttribute('data-i18n-html');
        if (dict[key] !== undefined) el.innerHTML = dict[key];
      });
      var esEl = document.getElementById('lang-es');
      var enEl = document.getElementById('lang-en');
      var btn  = document.getElementById('lang-toggle');
      if (lang === 'es') {
        esEl.classList.add('lang-active');   esEl.classList.remove('lang-inactive');
        enEl.classList.add('lang-inactive'); enEl.classList.remove('lang-active');
        btn.setAttribute('aria-label', 'Switch to English');
        btn.setAttribute('title', 'Switch to English');
      } else {
        enEl.classList.add('lang-active');   enEl.classList.remove('lang-inactive');
        esEl.classList.add('lang-inactive'); esEl.classList.remove('lang-active');
        btn.setAttribute('aria-label', 'Cambiar a Español');
        btn.setAttribute('title', 'Cambiar a Español');
      }
      document.documentElement.setAttribute('lang', lang);
    }

    var currentLang = (function() {
      var s = localStorage.getItem('rp-lang');
      if (s === 'es' || s === 'en') return s;
      return navigator.language.startsWith('es') ? 'es' : 'en';
    })();
    if (currentLang !== 'es') applyLang(currentLang);

    document.getElementById('lang-toggle').addEventListener('click', function() {
      currentLang = currentLang === 'es' ? 'en' : 'es';
      localStorage.setItem('rp-lang', currentLang);
      applyLang(currentLang);
    });

    /* HAMBURGER */
    var hamburger  = document.getElementById('hamburger');
    var mobileMenu = document.getElementById('mobile-menu');
    if (hamburger) hamburger.addEventListener('click', function() { mobileMenu.classList.toggle('open'); });
    if (mobileMenu) mobileMenu.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', function() { mobileMenu.classList.remove('open'); });
    });

    /* COPY IP */
    var copyBtn   = document.getElementById('copy-btn');
    var copyLabel = document.getElementById('copy-label');
    if (copyBtn) copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText('cs2.randompicks.es:27015');
      copyLabel.textContent = currentLang === 'es' ? '¡Copiado!' : 'Copied!';
      setTimeout(function() { copyLabel.textContent = t[currentLang]['copy-label']; }, 2000);
    });

    /* FAQ ACCORDION */
    document.querySelectorAll('.faq-question').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx    = btn.getAttribute('data-faq');
        var answer = document.getElementById('faq-answer-' + idx);
        var isOpen = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.faq-question').forEach(function(b) {
          b.setAttribute('aria-expanded', 'false');
          b.closest('.faq-item').classList.remove('open');
        });
        if (!isOpen) {
          btn.setAttribute('aria-expanded', 'true');
          btn.closest('.faq-item').classList.add('open');
        }
      });
    });
  </script>
